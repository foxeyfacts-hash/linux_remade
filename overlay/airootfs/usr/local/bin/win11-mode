#!/usr/bin/env bash
set -euo pipefail

apply_user() {
  local mode="$1"
  local profile="/usr/share/win11/modes/profiles/${mode}.conf"
  if [ ! -f "$profile" ]; then
    exit 0
  fi
  # shellcheck disable=SC1090
  source "$profile"
  if [ "${KWIN_COMPOSITING:-on}" = "off" ]; then
    qdbus org.kde.KWin /Compositor suspend >/dev/null 2>&1 || true
  else
    qdbus org.kde.KWin /Compositor resume >/dev/null 2>&1 || true
  fi
}

if [ "${1:-}" = "--apply-user" ]; then
  apply_user "${2:-balanced}"
  exit 0
fi

MODE="${1:-}"
if [ -z "$MODE" ]; then
  echo "Usage: win11-mode {performance|balanced|quality}" >&2
  exit 1
fi

PROFILE="/usr/share/win11/modes/profiles/${MODE}.conf"
if [ ! -f "$PROFILE" ]; then
  echo "Unknown mode: $MODE" >&2
  exit 1
fi

# shellcheck disable=SC1090
source "$PROFILE"

# CPU governor
if [ -n "${CPU_GOVERNOR:-}" ]; then
  for gov in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
    [ -f "$gov" ] && echo "$CPU_GOVERNOR" > "$gov" || true
  done
fi

# I/O scheduler
if [ -n "${IO_SCHEDULER:-}" ]; then
  for sched in /sys/block/*/queue/scheduler; do
    [ -f "$sched" ] && echo "$IO_SCHEDULER" > "$sched" || true
  done
fi

# Apply sysctl
sysctl --system >/dev/null 2>&1 || true

# Store default mode
mkdir -p /etc/win11
echo "$MODE" > /etc/win11/mode

exit 0